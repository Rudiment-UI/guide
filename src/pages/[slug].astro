---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Guide from '../layouts/Guide.astro';
import Ornament from '../components/Ornament.astro';
import ChapterMark from '../components/ChapterMark.astro';

export async function getStaticPaths() {
  const entries = await getCollection('guide');
  return entries
    .filter((entry) => entry.data.order > 0)
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

interface Props {
  entry: CollectionEntry<'guide'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const all = await getCollection('guide');
const ordered = all.sort((a, b) => a.data.order - b.data.order);
const index = ordered.findIndex((candidate) => candidate.id === entry.id);
const previous = ordered[index - 1];
const next = ordered[index + 1];
const total = ordered.length - 1;

const guideRepo = 'Rudiment-UI/guide';
const sourcePath = `building-your-own-component-library/${entry.id}.md`;
const editUrl = `https://github.com/${guideRepo}/edit/main/${sourcePath}`;
const issueTitle = encodeURIComponent(`Chapter ${entry.data.order}: ${entry.data.title} — correction`);
const issueUrl = `https://github.com/${guideRepo}/issues/new?title=${issueTitle}&labels=content`;
---

<Guide
  title={entry.data.title}
  description={entry.data.description}
  currentSlug={entry.id}
>
  <article>
    <header class="mb-16 border-b border-[color:var(--color-hairline)] pb-12 lg:mb-20 lg:pb-16">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <ChapterMark class="size-5" />
          <p class="flex items-center gap-3 text-[0.6875rem] tracking-[0.22em] uppercase text-[color:var(--color-ink-faint)] tabular-nums">
            <span>Chapter {String(entry.data.order).padStart(2, '0')}</span>
            <span class="inline-block h-px w-6 bg-[color:var(--color-hairline-strong)]" aria-hidden="true"></span>
            <span>of {String(total).padStart(2, '0')}</span>
          </p>
        </div>

        {/* PLACEMENT 1 — Chapter header meta link (subtle, top-right) */}
        <a
          href={editUrl}
          target="_blank"
          rel="noreferrer external"
          class="group/edit inline-flex items-center gap-2 text-[0.6875rem] tracking-[0.22em] uppercase text-[color:var(--color-ink-faint)] transition-colors hover:text-[color:var(--color-ink)] hover:underline hover:underline-offset-4"
        >
          <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="size-3.5 shrink-0">
            <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z" clip-rule="evenodd" />
          </svg>
          <span>Edit on GitHub</span>
        </a>
      </div>

      <h1 class="mt-8 font-display text-4xl font-normal tracking-tight text-pretty text-[color:var(--color-ink)] sm:text-5xl lg:text-6xl max-w-[28ch]">
        {entry.data.title}
      </h1>

      <p class="mt-6 max-w-[58ch] text-lg leading-8 text-pretty text-[color:var(--color-ink-muted)]">
        {entry.data.description}
      </p>
    </header>

    <div class="prose">
      <Content />
    </div>

    <div class="my-20 flex justify-center">
      <Ornament />
    </div>

    <nav aria-label="Chapter navigation" class="mt-12 border-t border-[color:var(--color-hairline)] pt-10">
      <ul role="list" class="grid gap-8 sm:grid-cols-2">
        {previous ? (
          <li class="sm:col-start-1">
            <a
              href={previous.data.order === 0 ? '/' : `/${previous.id}/`}
              rel="prev"
              class="group prev flex flex-col gap-2 rounded-lg border border-transparent p-4 -m-4 transition-colors hover:border-[color:var(--color-hairline)] hover:bg-[color:var(--color-canvas-sunk)]"
            >
              <span class="text-[0.6875rem] tracking-[0.22em] uppercase text-[color:var(--color-ink-faint)]">
                ← Previous
                {previous.data.order > 0 && (
                  <span class="ml-1 tabular-nums">· Chapter {String(previous.data.order).padStart(2, '0')}</span>
                )}
              </span>
              <span class="group-hover:underline group-hover:underline-offset-4 font-display text-xl tracking-tight text-[color:var(--color-ink)] transition-colors group-hover/prev:text-[color:var(--color-accent)] text-pretty">
                {previous.data.title}
              </span>
            </a>
          </li>
        ) : <li aria-hidden="true" />}

        {next && (
          <li class="sm:col-start-2">
            <a
              href={`/${next.id}/`}
              rel="next"
              class="group next flex flex-col items-end gap-2 rounded-lg border border-transparent p-4 -m-4 text-right transition-colors hover:border-[color:var(--color-hairline)] hover:bg-[color:var(--color-canvas-sunk)]"
            >
              <span class="text-[0.6875rem] tracking-[0.22em] uppercase text-[color:var(--color-ink-faint)] tabular-nums">
                Next · Chapter {String(next.data.order).padStart(2, '0')} →
              </span>
              <span class="group-hover:underline group-hover:underline-offset-4 font-display text-xl tracking-tight text-[color:var(--color-ink)] transition-colors group-hover/next:text-[color:var(--color-accent)] text-pretty">
                {next.data.title}
              </span>
            </a>
          </li>
        )}
      </ul>
    </nav>

    {/* PLACEMENT 2 — End-of-chapter card (prominent, after chapter nav) */}
    <aside
      aria-labelledby="feedback-heading"
      class="mt-16 rounded-lg border border-[color:var(--color-hairline)] bg-[color:var(--color-canvas-sunk)] p-6 sm:p-8"
    >
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between sm:gap-8">
        <div class="max-w-[48ch]">
          <p class="text-[0.6875rem] tracking-[0.22em] uppercase text-[color:var(--color-ink-faint)]">
            Contribute
          </p>
          <h2 id="feedback-heading" class="mt-2 font-display text-2xl tracking-tight text-[color:var(--color-ink)]">
            Spot an error in this chapter?
          </h2>
          <p class="mt-3 text-sm leading-6 text-[color:var(--color-ink-muted)]">
            This guide is open-source. You can open a pull request with a fix or file an issue describing what's off.
          </p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-3">
          <a
            href={editUrl}
            target="_blank"
            rel="noreferrer external"
            class="inline-flex items-center gap-2 rounded-full bg-[color:var(--color-ink)] px-4 py-2 text-sm font-medium text-[color:var(--color-canvas)] transition-colors hover:bg-[color:var(--color-accent)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent)]"
          >
            <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="size-4 shrink-0">
              <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z" clip-rule="evenodd" />
            </svg>
            Open a pull request
          </a>
          <a
            href={issueUrl}
            target="_blank"
            rel="noreferrer external"
            class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-hairline-strong)] px-4 py-2 text-sm font-medium text-[color:var(--color-ink)] transition-colors hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
          >
            Report an issue
          </a>
        </div>
      </div>
    </aside>
  </article>
</Guide>
