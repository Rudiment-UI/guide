---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 28 28"
  fill="none"
  aria-hidden="true"
  class:list={["text-[color:var(--color-ink)]", className]}
>
  <g stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
    <rect x="4.75" y="4.75" width="11" height="11" rx="1.5" />
    <rect x="12.25" y="12.25" width="11" height="11" rx="1.5" fill="var(--color-canvas)" />
  </g>
</svg>
