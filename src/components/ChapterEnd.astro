---
interface Props {
  label: string;
  href?: string;
  class?: string;
}

const { label, href, class: className } = Astro.props;
---

<div class:list={["flex items-center gap-4 sm:gap-6", className]}>
  <span
    class="h-px flex-1 bg-gradient-to-r from-transparent via-[color:var(--color-hairline-strong)] to-transparent"
    aria-hidden="true"
  ></span>

  {href ? (
    <a
      href={href}
      class="group/end -my-1 inline-flex items-center gap-2 rounded-full px-3 py-1 text-[0.6875rem] tracking-[0.22em] uppercase text-[color:var(--color-ink-faint)] transition-colors hover:text-[color:var(--color-ink)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent)]"
    >
      <span>{label}</span>
      <svg
        viewBox="0 0 16 16"
        fill="none"
        aria-hidden="true"
        class="size-3 shrink-0 transition-transform group-hover/end:-translate-y-0.5"
      >
        <path
          d="M8 13V3M4 7l4-4 4 4"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
  ) : (
    <span class="text-[0.6875rem] tracking-[0.22em] uppercase text-[color:var(--color-ink-faint)]">
      {label}
    </span>
  )}

  <span
    class="h-px flex-1 bg-gradient-to-r from-transparent via-[color:var(--color-hairline-strong)] to-transparent"
    aria-hidden="true"
  ></span>
</div>
