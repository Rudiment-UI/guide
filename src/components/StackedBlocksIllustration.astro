---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 360 240"
  fill="none"
  role="img"
  aria-label="Illustration of stacked component primitives"
  class:list={["text-[color:var(--color-ink)]", className]}
>
  <g stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
    <rect x="40.5" y="40.5" width="140" height="80" rx="4" fill="var(--color-canvas-raised)" />
    <rect x="90.5" y="70.5" width="140" height="80" rx="4" fill="var(--color-canvas-raised)" />
    <rect x="140.5" y="100.5" width="140" height="80" rx="4" fill="var(--color-canvas-raised)" />

    <line x1="60" y1="62" x2="120" y2="62" stroke-dasharray="2 3" opacity="0.55" />
    <line x1="60" y1="80" x2="140" y2="80" opacity="0.35" />
    <line x1="60" y1="96" x2="100" y2="96" opacity="0.35" />

    <line x1="110" y1="92" x2="170" y2="92" stroke-dasharray="2 3" opacity="0.55" />
    <line x1="110" y1="110" x2="200" y2="110" opacity="0.35" />
    <line x1="110" y1="126" x2="150" y2="126" opacity="0.35" />

    <line x1="160" y1="122" x2="220" y2="122" stroke-dasharray="2 3" opacity="0.55" />
    <line x1="160" y1="140" x2="250" y2="140" opacity="0.35" />
    <line x1="160" y1="156" x2="200" y2="156" opacity="0.35" />
  </g>

  <g stroke="var(--color-accent)" stroke-width="1" stroke-linecap="round" fill="none">
    <circle cx="300" cy="60" r="18" />
    <path d="M292 60 h16 M300 52 v16" opacity="0.6" />
  </g>

  <g stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.45">
    <path d="M20 210 h320" stroke-dasharray="1 4" />
  </g>
</svg>
