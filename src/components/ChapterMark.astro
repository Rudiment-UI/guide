---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  aria-hidden="true"
  class:list={["text-[color:var(--color-ink-faint)]", className]}
>
  <g stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
    <rect x="4.5" y="4.5" width="9" height="9" rx="1.25" />
    <rect x="10.5" y="10.5" width="9" height="9" rx="1.25" opacity="0.55" />
  </g>
</svg>
